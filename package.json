{
  "name": "memotask",
  "version": "5.0.3",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "vitest run tests/api",
    "test:shared": "vitest run tests/markdown-todos.test.ts tests/state-machines.test.ts",
    "worker:dev": "wrangler dev worker/index.ts --local",
    "worker:deploy": "wrangler deploy",
    "electron:pack": "npm run build && electron-builder --dir --config electron-builder.yml",
    "electron:build": "npm run build && electron-builder --win --config electron-builder.yml",
    "tauri:build": "tauri build",
    "android:init": "cap add android",
    "android:sync": "npm run build -- --mode capacitor && cap sync android",
    "android:build": "npm run android:sync && powershell -ExecutionPolicy Bypass -File scripts/android-build.ps1 -Release",
    "db:migrate:local": "wrangler d1 migrations apply memotask-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply memotask-db --remote",
    "e2e": "echo \"旧版前端 e2e 已清理；新版 UI 实现后按 docs/UI/memotask-ui-design-contract.md 重建。\""
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "hono": "^4.10.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@cloudflare/workers-types": "^4.20260620.0",
    "@tauri-apps/cli": "^2.6.3",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^2.1.8",
    "wrangler": "^4.23.0"
  },
  "description": "MemoTask 是一个低压力的个人 Memo 待办整理工具。它的核心思路很简单：先把脑子里的想法、计划、链接、琐事写成一条 Memo，再让人工智能把这条 Memo 内部拆成可执行的待办项。用户不需要一开始就想清楚分类、日期和提醒，只需要先记录，再整理。",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RivenRussell/MemoTask.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/RivenRussell/MemoTask/issues"
  },
  "homepage": "https://github.com/RivenRussell/MemoTask#readme"
}
